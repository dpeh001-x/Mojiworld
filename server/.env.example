# LevelX server environment variables.
# Copy this file to `.env` (gitignored) and fill in real values for local
# development; use your platform's secrets manager in production.

# REQUIRED in production — used to HMAC-sign session tokens. Minimum 16
# chars, 32+ recommended. Generate with:
#   openssl rand -hex 32
# Leave blank in development and the server will generate an ephemeral
# secret at boot (all sessions invalidate on restart).
SECRET=

# Port the HTTP + WS server listens on. Fly.io / Railway inject their own.
PORT=8080

# Path to the SQLite database file. In Docker, this is /app/data/levelx.db
# with a mounted volume so data survives redeploys.
DB_PATH=./data/levelx.db

# How long a session token is valid.
SESSION_TTL_DAYS=30

# Per-room player cap.
MAX_PER_ROOM=16

# Max chat characters the server will relay (clients already cap to 60).
MAX_CHAT_LEN=200

# Max player display-name length.
MAX_NAME_LEN=20

# Set to "production" on deploy. In prod, SECRET becomes mandatory — the
# server refuses to boot without it.
NODE_ENV=development
