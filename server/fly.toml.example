# Example fly.io deploy config for LevelX.
# Copy to fly.toml and edit the app name.
#
# First-time setup:
#   fly launch --no-deploy                 # creates the app, wires config
#   fly volumes create levelx_data --size 1
#   fly secrets set SECRET=$(openssl rand -hex 32)
#   fly deploy
#
# The volume keeps the SQLite DB + any future save files across redeploys.

app = "levelx-mp"   # <-- change to your Fly app name
primary_region = "iad"

[build]
  dockerfile = "Dockerfile"

[http_service]
  internal_port = 8080
  force_https = true
  auto_stop_machines = true
  auto_start_machines = true
  min_machines_running = 0     # scale to zero when nobody's playing
  processes = ["app"]

  [http_service.concurrency]
    type = "requests"
    soft_limit = 100
    hard_limit = 200

# Persist SQLite across redeploys / restarts.
[mounts]
  source      = "levelx_data"
  destination = "/app/data"

[env]
  NODE_ENV       = "production"
  PORT           = "8080"
  DB_PATH        = "/app/data/levelx.db"
  MAX_PER_ROOM   = "16"
  SESSION_TTL_DAYS = "30"
  # SECRET is set via `fly secrets set SECRET=...` (do NOT commit it)

[[vm]]
  cpu_kind = "shared"
  cpus     = 1
  memory_mb = 256   # plenty for a small MMORPG relay

# Optional health probe the platform uses for load balancing.
[[http_service.checks]]
  type = "http"
  path = "/health"
  interval = "30s"
  timeout  = "5s"
