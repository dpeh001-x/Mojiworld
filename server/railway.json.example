{
  "_comment": "Example railway.app deploy config. Copy to railway.json.",
  "_setup": [
    "railway login",
    "railway init",
    "railway variables set SECRET=$(openssl rand -hex 32)",
    "railway variables set NODE_ENV=production",
    "railway variables set MAX_PER_ROOM=16",
    "railway variables set DB_PATH=/data/levelx.db",
    "railway volume create --mount /data --size 1GB",
    "railway up"
  ],

  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "node server.js",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 5,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
