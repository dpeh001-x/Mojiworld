// gear_erase.js — BAKED equipment pixel-erase bitmaps.
// =============================================================================
// Per-sprite cleaned WebP data-URLs, keyed by equipment spriteId ('arm:<name>'
// / 'wpn:<name>'). Generated by the in-game Gear Align (T) overlay → the
// "Export Erase" button: erase pixels in the tool, click Export Erase, then
// paste the copied `window.LX_EQ_ERASE_DATA = { ... }` block over this file and
// commit it.
//
// Why this file exists: the Erase tool saves to localStorage, which is scoped
// PER ORIGIN. An erase made on http://localhost is invisible when the game is
// opened from file:// or raw.githack (a different origin = a separate, empty
// localStorage), so the original art reappears. Baking the erases into this
// committed file — loaded before the main script in mojiworld_game.html — makes
// them apply on every origin. A live localStorage edit still wins over the baked
// value (an explicit null there un-bakes a sprite), so the dev tool keeps working.
//
// Empty by default; populate via Export Erase. If this file is missing the game
// still runs (just no baked erases).
window.LX_EQ_ERASE_DATA = window.LX_EQ_ERASE_DATA || {};
